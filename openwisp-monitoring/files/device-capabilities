#!/bin/sh

CHECKED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

json_escape() {
	printf "%s" "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

command_exists() {
	command -v "$1" >/dev/null 2>&1
}

package_version() {
	package="$1"
	if command_exists opkg; then
		opkg list-installed "$package" 2>/dev/null | awk -F' - ' 'NR == 1 {print $2}'
	elif [ -r /usr/lib/opkg/status ]; then
		awk -v pkg="$package" '
			$1 == "Package:" && $2 == pkg {found=1}
			found && $1 == "Version:" {print $2; exit}
			$0 == "" {found=0}
		' /usr/lib/opkg/status
	fi
}

status_json() {
	key="$1"
	status="$2"
	supported="$3"
	version="$4"
	reason="$5"
	evidence="$6"
	printf '"%s":{"supported":%s,"status":"%s","version":"%s","reason":"%s","evidence":%s,"checked_at":"%s"}' \
		"$(json_escape "$key")" \
		"$supported" \
		"$(json_escape "$status")" \
		"$(json_escape "$version")" \
		"$(json_escape "$reason")" \
		"$evidence" \
		"$(json_escape "$CHECKED_AT")"
}

bool_json() {
	[ "$1" = "1" ] && printf "true" || printf "false"
}

count_processes() {
	pattern="$1"
	pgrep -f "$pattern" 2>/dev/null | awk 'END {print NR + 0}'
}

openwisp_version="$(package_version openwisp-monitoring)"
iperf3_version="$(package_version iperf3)"
[ -n "$iperf3_version" ] || iperf3_version="$(package_version iperf3-ssl)"

has_probe=0
[ -x /usr/sbin/openwisp-path-quality-probe ] && has_probe=1
has_iperf3=0
command_exists iperf3 && has_iperf3=1
has_wrapper=0
[ -x /usr/sbin/ebrain-iperf3 ] && has_wrapper=1
has_monitoring_agent=0
[ -x /usr/sbin/openwisp-monitoring ] && has_monitoring_agent=1
has_ubus=0
command_exists ubus && has_ubus=1
has_opkg=0
command_exists opkg && has_opkg=1

probe_process_count="$(count_processes "/usr/sbin/openwisp-path-quality-probe")"
probe_singleton=0
[ "$probe_process_count" -le 1 ] 2>/dev/null && probe_singleton=1

probe_instance_running=0
if command_exists ubus; then
	if ubus call service list '{"name":"openwisp-monitoring"}' 2>/dev/null | grep -q 'openwisp-monitoring_probe'; then
		probe_instance_running=1
	fi
fi

board_json="{}"
if command_exists ubus; then
	board_json="$(ubus call system board 2>/dev/null || printf '{}')"
fi
release_desc=""
target=""
board_name=""
if command_exists jsonfilter; then
	release_desc="$(printf "%s" "$board_json" | jsonfilter -e '@.release.description' 2>/dev/null)"
	target="$(printf "%s" "$board_json" | jsonfilter -e '@.release.target' 2>/dev/null)"
	board_name="$(printf "%s" "$board_json" | jsonfilter -e '@.board_name' 2>/dev/null)"
fi

path_quality_supported=0
path_quality_status="unsupported"
path_quality_reason="openwisp-path-quality-probe missing"
if [ "$has_probe" = "1" ] && [ "$has_monitoring_agent" = "1" ]; then
	path_quality_supported=1
	path_quality_status="supported"
	path_quality_reason="probe runner and monitoring payload append are available"
fi

iperf3_supported=0
iperf3_status="unsupported"
iperf3_reason="iperf3 wrapper missing"
if [ "$has_iperf3" = "1" ] && [ "$has_wrapper" = "1" ]; then
	iperf3_supported=1
	iperf3_status="supported"
	iperf3_reason="iperf3 binary and ebrain wrapper are available"
elif [ "$has_iperf3" = "0" ]; then
	iperf3_reason="iperf3 binary missing"
fi

rttys_supported=0
rttys_status="unknown"
rttys_reason="RTTYS command channel is verified by controller preflight"
if [ "$has_wrapper" = "1" ]; then
	rttys_supported=1
	rttys_status="supported"
	rttys_reason="device has controlled command wrappers; controller still verifies live RTTYS session"
fi

probe_evidence="{\"probe_script\":$(bool_json "$has_probe"),\"monitoring_agent\":$(bool_json "$has_monitoring_agent"),\"procd_probe_instance\":$(bool_json "$probe_instance_running"),\"probe_process_count\":$probe_process_count,\"single_instance\":$(bool_json "$probe_singleton")}"
iperf_evidence="{\"iperf3_binary\":$(bool_json "$has_iperf3"),\"wrapper_script\":$(bool_json "$has_wrapper")}"
rttys_evidence="{\"wrapper_script\":$(bool_json "$has_wrapper")}"

cat <<EOF
{"schema_version":1,"checked_at":"$(json_escape "$CHECKED_AT")","firmware":{"supported":$(bool_json "$has_ubus"),"status":"$([ "$has_ubus" = "1" ] && printf supported || printf unknown)","version":"$(json_escape "$release_desc")","reason":"$([ "$has_ubus" = "1" ] && printf 'ubus system board available' || printf 'ubus missing')","evidence":{"release_description":"$(json_escape "$release_desc")","target":"$(json_escape "$target")","board_name":"$(json_escape "$board_name")"},"checked_at":"$(json_escape "$CHECKED_AT")"},"packages":{"openwisp-monitoring":{"supported":$([ -n "$openwisp_version" ] && printf true || printf false),"status":"$([ -n "$openwisp_version" ] && printf supported || printf unknown)","version":"$(json_escape "$openwisp_version")","reason":"$([ -n "$openwisp_version" ] && printf 'package installed' || printf 'package version not found')","evidence":{"opkg":$(bool_json "$has_opkg")},"checked_at":"$(json_escape "$CHECKED_AT")"},"iperf3":{"supported":$(bool_json "$has_iperf3"),"status":"$([ "$has_iperf3" = "1" ] && printf supported || printf unsupported)","version":"$(json_escape "$iperf3_version")","reason":"$([ "$has_iperf3" = "1" ] && printf 'iperf3 binary available' || printf 'iperf3 binary missing')","evidence":{"binary":$(bool_json "$has_iperf3"),"opkg":$(bool_json "$has_opkg")},"checked_at":"$(json_escape "$CHECKED_AT")"}},"services":{"path_quality_probe":{"supported":$(bool_json "$probe_instance_running"),"status":"$([ "$probe_instance_running" = "1" ] && printf supported || printf degraded)","version":"","reason":"$([ "$probe_instance_running" = "1" ] && printf 'procd probe instance detected' || printf 'procd probe instance not detected')","evidence":$probe_evidence,"checked_at":"$(json_escape "$CHECKED_AT")"}},"features":{$(status_json "path_quality.v1" "$path_quality_status" "$(bool_json "$path_quality_supported")" "1" "$path_quality_reason" "$probe_evidence"),$(status_json "iperf3.v1" "$iperf3_status" "$(bool_json "$iperf3_supported")" "1" "$iperf3_reason" "$iperf_evidence"),$(status_json "rttys_command.v1" "$rttys_status" "$(bool_json "$rttys_supported")" "1" "$rttys_reason" "$rttys_evidence")}}
EOF
